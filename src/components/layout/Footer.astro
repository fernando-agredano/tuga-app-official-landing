  const modal    = document.getElementById("footer-info-modal");
  const card     = document.getElementById("footer-modal-card");
  const backdrop = document.getElementById("footer-modal-backdrop");
  const closeBtn = document.getElementById("footer-modal-close");
  const titleEl  = document.getElementById("footer-modal-title");
  const bodyEl   = document.getElementById("footer-modal-body");

  function openFooterModal(key: string) {
    const entry = CONTENT[key];
    if (!entry || !titleEl || !bodyEl) return;
    titleEl.textContent = entry.title;
    bodyEl.innerHTML = entry.html;
    bodyEl.scrollTop = 0;
    modal?.classList.remove("hidden");
    modal?.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => requestAnimationFrame(() => {
      backdrop?.classList.remove("opacity-0");
      card?.classList.remove("scale-95", "opacity-0");
      card?.classList.add("scale-100");
    }));
  }

  function closeFooterModal() {
    card?.classList.remove("scale-100");
    card?.classList.add("scale-95", "opacity-0");
    backdrop?.classList.add("opacity-0");
    setTimeout(() => {
      modal?.classList.add("hidden");
      modal?.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    }, 300);
  }

  document.querySelectorAll<HTMLElement>(".footer-modal-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      const key = btn.dataset.footerModal ?? "";
      openFooterModal(key);
    });
  });

  closeBtn?.addEventListener("click", closeFooterModal);
  backdrop?.addEventListener("click", closeFooterModal);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeFooterModal();
  });
</script>
