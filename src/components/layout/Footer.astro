---
import TugaBrandLogo from "@/components/brand/TugaBrandLogo.astro";
const socialLinks = [
  {
    name: "Instagram",
    href: "#",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>`,
  },
  {
    name: "X",
    href: "#",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932 6.064-6.932zm-1.292 19.49h2.039L6.486 3.24H4.298l13.311 17.403z"/></svg>`,
  },
  {
    name: "Facebook",
    href: "#",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  },
  {
    name: "GitHub",
    href: "#",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
  },
];
const product = ["Funciones", "Precios", "App Store", "Play Store", "Soporte"];
const company = ["Nosotros", "Carreras", "Prensa", "Partners", "Contacto"];
const legal  = ["Privacidad", "Términos", "Política de Cookies", "Aviso Legal"];
---

<footer class="border-t border-zinc-900 bg-black pt-24 pb-12">
  <div class="container mx-auto px-4">
    <div class="mb-20 grid grid-cols-1 sm:grid-cols-2 gap-12 md:grid-cols-4 lg:grid-cols-5">
      <div class="sm:col-span-2 lg:col-span-2">
        <div class="mb-6 flex justify-center sm:justify-start">
          <TugaBrandLogo />
        </div>

        <p class="max-w-xs text-lg leading-relaxed text-zinc-500 text-center sm:text-left mx-auto sm:mx-0">
          Redefiniendo la entrega de comida para el estilo de vida urbano
          moderno. Calidad premium. Velocidad récord.
        </p>

        <div class="mt-8 flex gap-4 justify-center sm:justify-start">
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                onclick="event.preventDefault()"
                class="flex h-10 w-10 items-center justify-center rounded-full bg-zinc-900 text-zinc-500 transition-all lg:hover:bg-tuga-brand lg:hover:text-white active:bg-tuga-brand active:text-white"
                aria-label={link.name}
              >
                <Fragment set:html={link.svg} />
              </a>
            ))
          }
        </div>
      </div>

      <div class="text-center sm:text-left">
        <h4 class="mb-6 font-bold text-white">Producto</h4>
        <ul class="space-y-4">
          {
            product.map((item) => (
              <li>
                <button
                  type="button"
                  data-footer-modal={item}
                  class="footer-modal-trigger text-zinc-500 transition-all duration-300 lg:hover:text-tuga-brand active:text-tuga-brand cursor-pointer"
                >
                  {item}
                </button>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="text-center sm:text-left">
        <h4 class="mb-6 font-bold text-white">Empresa</h4>
        <ul class="space-y-4">
          {
            company.map((item) => (
              <li>
                <button
                  type="button"
                  data-footer-modal={item}
                  class="footer-modal-trigger text-zinc-500 transition-all duration-300 lg:hover:text-tuga-brand active:text-tuga-brand cursor-pointer"
                >
                  {item}
                </button>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="text-center sm:text-left">
        <h4 class="mb-6 font-bold text-white">Legal</h4>
        <ul class="space-y-4">
          {
            legal.map((item) => (
              <li>
                <button
                  type="button"
                  data-footer-modal={item}
                  class="footer-modal-trigger text-zinc-500 transition-all duration-300 lg:hover:text-tuga-brand active:text-tuga-brand cursor-pointer"
                >
                  {item}
                </button>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="flex flex-col items-center justify-between gap-6 border-t border-zinc-900 pt-12 md:flex-row"
    >
      <p class="text-sm text-zinc-600">
        © 2026 TugaApp. Todos los derechos reservados.
      </p>

      <div class="flex items-center gap-2">
        <span class="text-xs font-bold tracking-[0.2em] text-zinc-700 uppercase">
          Powered by
        </span>
        <span class="text-xs font-bold tracking-tight text-zinc-400">BYTE</span>
      </div>
    </div>
  </div>
</footer>

<!-- Footer Info Modal -->
<div
  id="footer-info-modal"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  class="fixed inset-0 z-[500] hidden flex items-center justify-center p-4"
>
  <div id="footer-modal-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-md opacity-0 transition-opacity duration-200"></div>

  <div
    id="footer-modal-card"
    class="relative z-10 flex w-full max-w-2xl scale-95 opacity-0 flex-col overflow-hidden rounded-[2rem] border border-white/10 bg-zinc-950 shadow-[0_30px_80px_rgba(0,0,0,0.7),0_0_60px_rgba(115,148,106,0.1)] transition-all duration-300"
    style="max-height: 85vh;"
  >
    <!-- Top accent -->
    <div class="h-px w-full shrink-0 bg-gradient-to-r from-transparent via-tuga-brand/60 to-transparent"></div>

    <!-- Inner glow -->
    <div class="pointer-events-none absolute -top-20 left-1/2 h-40 w-40 -translate-x-1/2 rounded-full bg-tuga-brand/20 blur-3xl"></div>

    <!-- Header (sticky) -->
    <div class="relative flex shrink-0 items-center justify-between border-b border-white/8 px-6 py-5">
      <h3 id="footer-modal-title" class="text-lg font-black tracking-tight text-white"></h3>
      <button
        id="footer-modal-close"
        type="button"
        aria-label="Cerrar"
        class="flex h-8 w-8 items-center justify-center rounded-full bg-zinc-800 text-zinc-400 transition-colors hover:bg-zinc-700 hover:text-white active:scale-95"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>

    <!-- Scrollable body -->
    <div id="footer-modal-body" class="overflow-y-auto px-6 py-6"></div>
  </div>
</div>

<script>
  // SVG icon helpers — use currentColor so they're always zinc-400 (no emoji color)
  const S = 'xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"';
  const sm = (p: string) => `<span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-white/10 bg-white/[0.04] text-zinc-400"><svg ${S} width="16" height="16" viewBox="0 0 24 24">${p}</svg></span>`;
  const lg = (p: string) => `<span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.04] text-zinc-400"><svg ${S} width="32" height="32" viewBox="0 0 24 24">${p}</svg></span>`;

  const I = {
    search:  sm('<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>'),
    zap:     sm('<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>'),
    pin:     sm('<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>'),
    bell:    sm('<path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>'),
    card:    sm('<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>'),
    mail:    sm('<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>'),
    clock:   sm('<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>'),
    phone:   sm('<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>'),
    package: sm('<path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>'),
    msg:     sm('<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>'),
    help:    sm('<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/>'),
    users:   sm('<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>'),
    phoneLg: lg('<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>'),
  };

  const CONTENT: Record<string, { title: string; html: string }> = {
    "Funciones": {
      title: "Funciones de TugaApp",
      html: `<div class="space-y-5"><p class="text-zinc-400 leading-relaxed">TugaApp fue diseñada para simplificar la experiencia de pedir en tu región. Cada función está pensada para hacer el proceso más rápido, claro y confiable.</p><div class="space-y-3"><div class="flex gap-4 p-4 rounded-2xl border border-white/8 bg-white/[0.02]">${I.search}<div><h4 class="font-bold text-white mb-1 text-sm">Exploración de negocios</h4><p class="text-sm text-zinc-400">Navega entre restaurantes y comercios locales. Filtra por categoría o tiempo de entrega.</p></div></div><div class="flex gap-4 p-4 rounded-2xl border border-white/8 bg-white/[0.02]">${I.zap}<div><h4 class="font-bold text-white mb-1 text-sm">Pedidos rápidos</h4><p class="text-sm text-zinc-400">Selecciona tus productos y confirma en segundos. Sin pasos innecesarios.</p></div></div><div class="flex gap-4 p-4 rounded-2xl border border-white/8 bg-white/[0.02]">${I.pin}<div><h4 class="font-bold text-white mb-1 text-sm">Ubicación inteligente</h4><p class="text-sm text-zinc-400">Establece tu dirección directamente desde la app. Sin explicaciones complicadas.</p></div></div><div class="flex gap-4 p-4 rounded-2xl border border-white/8 bg-white/[0.02]">${I.bell}<div><h4 class="font-bold text-white mb-1 text-sm">Notificaciones en tiempo real</h4><p class="text-sm text-zinc-400">Recibe actualizaciones en cada etapa: aceptado, en preparación, en camino y entregado.</p></div></div><div class="flex gap-4 p-4 rounded-2xl border border-white/8 bg-white/[0.02]">${I.card}<div><h4 class="font-bold text-white mb-1 text-sm">Pago en efectivo</h4><p class="text-sm text-zinc-400">Paga al recibir tu pedido. Simplicidad y confianza en cada transacción.</p></div></div></div></div>`
    },
    "Precios": {
      title: "Precios",
      html: `<div class="space-y-5"><div class="rounded-2xl border border-tuga-brand/30 bg-tuga-brand/5 p-6 text-center"><p class="text-5xl font-black text-tuga-brand mb-2">Gratis</p><p class="text-zinc-400">TugaApp es completamente gratuita para usuarios.</p></div><div class="space-y-3"><div class="flex items-start gap-3 p-4 rounded-2xl border border-white/8 bg-white/[0.02]"><span class="text-tuga-brand mt-0.5 font-bold shrink-0">✓</span><div><h4 class="font-semibold text-white text-sm">Sin suscripción</h4><p class="text-sm text-zinc-500">Descarga y usa la app sin pagar mensualidades ni cuotas de registro.</p></div></div><div class="flex items-start gap-3 p-4 rounded-2xl border border-white/8 bg-white/[0.02]"><span class="text-tuga-brand mt-0.5 font-bold shrink-0">✓</span><div><h4 class="font-semibold text-white text-sm">Sin cargos ocultos</h4><p class="text-sm text-zinc-500">Pagas exactamente lo que se muestra. Sin comisiones adicionales al usuario.</p></div></div><div class="flex items-start gap-3 p-4 rounded-2xl border border-white/8 bg-white/[0.02]"><span class="text-tuga-brand mt-0.5 font-bold shrink-0">✓</span><div><h4 class="font-semibold text-white text-sm">Costo de delivery transparente</h4><p class="text-sm text-zinc-500">El costo de entrega (si aplica) lo define cada negocio y se muestra antes de confirmar.</p></div></div></div><p class="text-xs text-zinc-600 text-center">Para negocios, consulta nuestro programa de Partners.</p></div>`
    },
    "App Store": {
      title: "App Store — iOS",
      html: `<div class="text-center space-y-6 py-4"><div class="flex justify-center">${I.phoneLg}</div><div><p class="text-sm font-semibold uppercase tracking-[0.25em] text-tuga-brand mb-2">Próximamente</p><h4 class="text-2xl font-black text-white mb-3">TugaApp en iOS</h4><p class="text-zinc-400 leading-relaxed max-w-sm mx-auto">Estamos trabajando para lanzar TugaApp en la App Store de Apple. Muy pronto podrás descargarla en tu iPhone o iPad.</p></div><div class="rounded-2xl border border-white/8 bg-white/[0.02] p-4"><p class="text-sm text-zinc-500">Compatible con <span class="text-zinc-300 font-medium">iOS 15+</span> · iPhone y iPad</p></div></div>`
    },
    "Play Store": {
      title: "Play Store — Android",
      html: `<div class="text-center space-y-6 py-4"><div class="flex justify-center">${I.phoneLg}</div><div><p class="text-sm font-semibold uppercase tracking-[0.25em] text-tuga-brand mb-2">Próximamente</p><h4 class="text-2xl font-black text-white mb-3">TugaApp en Android</h4><p class="text-zinc-400 leading-relaxed max-w-sm mx-auto">TugaApp llegará pronto a Google Play. Descárgala en tu smartphone Android y empieza a pedir en minutos.</p></div><div class="rounded-2xl border border-white/8 bg-white/[0.02] p-4"><p class="text-sm text-zinc-500">Compatible con <span class="text-zinc-300 font-medium">Android 9+</span></p></div></div>`
    },
    "Soporte": {
      title: "Soporte",
      html: `<div class="space-y-4"><p class="text-zinc-400 leading-relaxed">Estamos aquí para ayudarte. Si tienes alguna pregunta o problema, contáctanos.</p><div class="space-y-3"><div class="flex items-center gap-4 p-4 rounded-2xl border border-white/8 bg-white/[0.02]">${I.mail}<div><p class="font-semibold text-white text-sm">Correo electrónico</p><p class="text-tuga-brand text-sm">soporte@tugaapp.mx</p></div></div><div class="flex items-center gap-4 p-4 rounded-2xl border border-white/8 bg-white/[0.02]">${I.clock}<div><p class="font-semibold text-white text-sm">Tiempo de respuesta</p><p class="text-zinc-500 text-sm">Menos de 24 horas en días hábiles</p></div></div><div class="flex items-center gap-4 p-4 rounded-2xl border border-white/8 bg-white/[0.02]">${I.clock}<div><p class="font-semibold text-white text-sm">Horario de atención</p><p class="text-zinc-500 text-sm">Lunes a Sábado · 9:00 – 20:00</p></div></div></div></div>`
    },
    "Nosotros": {
      title: "Nosotros",
      html: `<div class="space-y-5"><div class="rounded-2xl border border-tuga-brand/20 bg-tuga-brand/5 p-5"><p class="text-zinc-300 leading-relaxed italic">"Creemos que pedir en tu región debería ser tan fácil como un mensaje, pero mucho más confiable."</p></div><p class="text-zinc-400 leading-relaxed">TugaApp nació de una necesidad real: conectar a las personas con los negocios de su comunidad de forma sencilla, rápida y sin complicaciones tecnológicas innecesarias.</p><div class="space-y-3"><div class="flex gap-3 p-4 rounded-2xl border border-white/8 bg-white/[0.02]"><span class="text-tuga-brand font-bold shrink-0 mt-0.5">◆</span><div><h4 class="font-semibold text-white mb-1 text-sm">Nuestra misión</h4><p class="text-sm text-zinc-400">Democratizar el delivery en regiones donde las grandes plataformas no llegan, dando visibilidad a los negocios locales.</p></div></div><div class="flex gap-3 p-4 rounded-2xl border border-white/8 bg-white/[0.02]"><span class="text-tuga-brand font-bold shrink-0 mt-0.5">◆</span><div><h4 class="font-semibold text-white mb-1 text-sm">Nuestra visión</h4><p class="text-sm text-zinc-400">Ser la plataforma de delivery de referencia en México para comunidades medianas y pequeñas, impulsando la economía local.</p></div></div><div class="flex gap-3 p-4 rounded-2xl border border-white/8 bg-white/[0.02]"><span class="text-tuga-brand font-bold shrink-0 mt-0.5">◆</span><div><h4 class="font-semibold text-white mb-1 text-sm">Impulsado por Byte</h4><p class="text-sm text-zinc-400">Desarrollado sobre la infraestructura de Byte: alta disponibilidad, seguridad y escalabilidad desde el primer día.</p></div></div></div></div>`
    },
    "Carreras": {
      title: "Carreras",
      html: `<div class="space-y-5"><div class="text-center py-2"><p class="text-sm font-semibold uppercase tracking-[0.25em] text-tuga-brand mb-2">Únete al equipo</p><p class="text-zinc-400 text-sm leading-relaxed max-w-md mx-auto">Estamos creciendo y buscamos personas apasionadas por la tecnología y el impacto local. Sé parte de algo grande desde el inicio.</p></div><div class="space-y-3"><div class="p-4 rounded-2xl border border-white/8 bg-white/[0.02]"><p class="text-xs text-tuga-brand font-semibold uppercase tracking-wider mb-1">Tecnología</p><h4 class="font-bold text-white text-sm">Desarrollador Mobile</h4><p class="text-xs text-zinc-500 mt-1">React Native · Remoto</p></div><div class="p-4 rounded-2xl border border-white/8 bg-white/[0.02]"><p class="text-xs text-tuga-brand font-semibold uppercase tracking-wider mb-1">Diseño</p><h4 class="font-bold text-white text-sm">UI/UX Designer</h4><p class="text-xs text-zinc-500 mt-1">Figma · Remoto / Híbrido</p></div><div class="p-4 rounded-2xl border border-white/8 bg-white/[0.02]"><p class="text-xs text-tuga-brand font-semibold uppercase tracking-wider mb-1">Operaciones</p><h4 class="font-bold text-white text-sm">Growth & Partnerships</h4><p class="text-xs text-zinc-500 mt-1">Full time · Presencial</p></div></div><p class="text-center text-sm text-zinc-500">Envía tu CV a <span class="text-tuga-brand">careers@tugaapp.mx</span></p></div>`
    },
    "Prensa": {
      title: "Prensa",
      html: `<div class="space-y-4"><p class="text-zinc-400 leading-relaxed">¿Eres periodista o medio de comunicación? Tenemos material listo para ti. Contáctanos y te enviamos el kit completo.</p><div class="space-y-3"><div class="flex items-center gap-4 p-4 rounded-2xl border border-white/8 bg-white/[0.02]">${I.package}<div><h4 class="font-semibold text-white text-sm">Kit de prensa</h4><p class="text-xs text-zinc-500">Logos, imágenes y capturas en alta resolución, más descripción completa de la plataforma.</p></div></div><div class="flex items-center gap-4 p-4 rounded-2xl border border-white/8 bg-white/[0.02]">${I.msg}<div><h4 class="font-semibold text-white text-sm">Entrevistas</h4><p class="text-xs text-zinc-500">Disponibles para hablar sobre la visión de la empresa y el impacto en el comercio local.</p></div></div><div class="flex items-center gap-4 p-4 rounded-2xl border border-white/8 bg-white/[0.02]">${I.mail}<div><h4 class="font-semibold text-white text-sm">Contacto de medios</h4><p class="text-tuga-brand text-sm">prensa@tugaapp.mx</p></div></div></div></div>`
    },
    "Partners": {
      title: "Partners",
      html: `<div class="space-y-5"><p class="text-zinc-400 leading-relaxed">¿Tienes un negocio y quieres llegar a más clientes? Únete a TugaApp y lleva tus ventas al siguiente nivel.</p><div class="space-y-3"><div class="flex gap-3 p-4 rounded-2xl border border-white/8 bg-white/[0.02]"><span class="text-tuga-brand font-black text-lg shrink-0">01</span><div><h4 class="font-semibold text-white text-sm">Regístrate</h4><p class="text-xs text-zinc-500">Completa el formulario con la información de tu negocio.</p></div></div><div class="flex gap-3 p-4 rounded-2xl border border-white/8 bg-white/[0.02]"><span class="text-tuga-brand font-black text-lg shrink-0">02</span><div><h4 class="font-semibold text-white text-sm">Configura tu menú</h4><p class="text-xs text-zinc-500">Agrega tus productos, precios y horarios desde el panel de control.</p></div></div><div class="flex gap-3 p-4 rounded-2xl border border-white/8 bg-white/[0.02]"><span class="text-tuga-brand font-black text-lg shrink-0">03</span><div><h4 class="font-semibold text-white text-sm">Recibe pedidos</h4><p class="text-xs text-zinc-500">Acepta y gestiona pedidos en tiempo real desde la app de negocios.</p></div></div></div><p class="text-center text-sm text-zinc-500">Más información: <span class="text-tuga-brand">partners@tugaapp.mx</span></p></div>`
    },
    "Contacto": {
      title: "Contacto",
