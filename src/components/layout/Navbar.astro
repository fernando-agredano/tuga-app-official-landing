---
import TugaBrandLogo from "@/components/brand/TugaBrandLogo.astro";
import { Menu, X } from "@lucide/astro";
import { NAV_LINKS } from "@/config/landing-sections";

const navTop =
  "fixed inset-x-0 top-0 z-[200] transition-[padding,background-color,border-color,backdrop-filter,box-shadow] duration-300 py-5 bg-transparent border-b border-transparent shadow-none";
---

<nav id="site-nav" class:list={[navTop, "invisible"]} aria-label="Principal">
  <div class="relative z-10 container mx-auto px-4">
    <div class="flex min-h-[3rem] items-center">
      <!-- Left: logo — flex-1 so it mirrors the right side width -->
      <div class="flex flex-1 items-center">
        <TugaBrandLogo class="shrink-0 py-0.5" />
      </div>

      <!-- Center: links — no flex growth, width is just the links -->
      <div
        class="hidden items-center gap-x-5 lg:flex xl:gap-x-7"
      >
        {
          NAV_LINKS.map(({ id, label }) => {
            const active = id === "inicio";
            return (
              <a
                href={`#${id}`}
                data-scroll-to={id}
                data-nav-id={id}
                class:list={[
                  "nav-desktop-link text-sm font-bold tracking-tight uppercase transition-colors border-b-2 pb-1 whitespace-nowrap",
                  active
                    ? "text-tuga-brand border-tuga-brand"
                    : "text-zinc-300 border-transparent hover:text-white hover:border-zinc-600",
                ]}
              >
                {label}
              </a>
            );
          })
        }
      </div>

      <!-- Right: CTA + mobile toggle — flex-1 justify-end mirrors left -->
      <div class="flex flex-1 items-center justify-end gap-3">
        <button
          type="button"
          data-scroll-to="support"
          data-cta-desktop
          class="hidden rounded-xl font-bold h-11 px-6 xl:px-7 text-sm uppercase tracking-wide transition-colors border glass-button border-white/15 lg:inline-flex lg:items-center"
        >
          Comenzar
        </button>

      <button
        type="button"
        id="nav-mobile-toggle"
        class="shrink-0 -mr-1 p-1.5 text-white transition-colors hover:text-tuga-brand lg:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <span id="nav-icon-menu">
          <Menu class="h-6 w-6" aria-hidden="true" />
        </span>
        <span id="nav-icon-close" class="hidden">
          <X class="h-6 w-6" aria-hidden="true" />
        </span>
      </button>
      </div>
    </div>
  </div>
</nav>

<!-- Overlay and panel are outside <nav> to avoid backdrop-filter containing-block issues on Chrome mobile -->
<div
  id="nav-mobile-overlay"
  class="fixed inset-0 z-[100] bg-black/65 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
  aria-hidden="true"
></div>

<div
  id="nav-mobile-panel"
  class="fixed inset-y-0 right-0 z-[150] w-[55%] max-w-[280px] translate-x-full overflow-y-auto border-l border-zinc-800/60 bg-zinc-950 px-5 pt-20 pb-10 transition-transform duration-500 lg:hidden"
  aria-hidden="true"
>
  <div class="flex flex-col gap-0.5">
    {
      NAV_LINKS.map(({ id, label }) => {
        const active = id === "inicio";
        return (
          <a
            href={`#${id}`}
            data-scroll-to={id}
            data-nav-id={id}
            class:list={[
              "nav-mobile-link text-left text-[11px] font-semibold uppercase tracking-widest transition-colors border-l-2 py-2.5 pl-4",
              active
                ? "border-tuga-brand text-tuga-brand"
                : "border-transparent text-zinc-300 hover:text-white hover:border-zinc-600",
            ]}
          >
            {label}
          </a>
        );
      })
    }
  </div>
</div>
