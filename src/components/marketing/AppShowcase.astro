---
import { Smartphone, Zap, ShieldCheck } from "@lucide/astro";

const features = [
  {
    title: "Interfaz intuitiva",
    desc: "Todo está diseñado para que pedir sea simple, claro y natural desde el primer momento, sin pasos innecesarios. Una presentación visual limpia y moderna que hace que explorar negocios y productos se sienta premium",
  },
  {
    title: "Acciones más rápidas",
    desc: "Navega, elige y confirma tu pedido con una experiencia ágil que reduce fricción en cada interacción.",
  },
  {
    title: "Confianza en cada pedido",
    desc: "Desde la confirmación hasta la entrega, cada detalle está pensado para ofrecer una experiencia segura y confiable.",
  },
] as const;

const icons = [Smartphone, Zap, ShieldCheck];
---

<section id="features" class="scroll-target overflow-hidden bg-zinc-950 py-24">
  <div class="container mx-auto px-4">
    <div
      data-explora-animate
      class="flex w-full flex-col gap-12 opacity-0 lg:flex-row lg:items-center lg:gap-14 xl:gap-16"
    >
      <div class="w-full min-w-0 lg:w-1/2">
        <h2 class="mb-4 text-sm font-bold tracking-[0.3em] text-zinc-500 uppercase">
          Explora
        </h2>
        <h3 class="mb-5 text-4xl font-bold tracking-tight text-white md:text-6xl">
          Los restaurantes de siempre{" "}
          <span
            class="bg-gradient-to-r from-zinc-200 to-zinc-600 bg-clip-text text-transparent"
          >
            ahora en la palma de tu mano
          </span>
        </h3>
        <p class="mb-10 text-base leading-relaxed text-zinc-400 md:text-lg">
          Explora una amplia variedad de restaurantes locales; olvídate de tener
          que buscar el número de cualquier lugar. Todo en la palma de tu mano:
          tus lugares favoritos y hasta los que no conocías, ahora a un clic de
          distancia.
        </p>

        <div
          class="rounded-[1.65rem] border border-white/10 bg-white/[0.04] p-6 backdrop-blur-md"
        >
          <p class="mb-3 text-xs font-bold tracking-[0.28em] text-zinc-500 uppercase">
            Delivery
          </p>
          <h4 class="mb-3 text-2xl font-bold tracking-tight text-white md:text-3xl">
            Pide fácil, recibe rápido
          </h4>
          <p class="mb-5 text-sm leading-relaxed text-zinc-400 md:text-base">
            Deja las explicaciones largas para que den con tu domicilio:
            simplemente establece la ubicación desde la app y recibe en minutos.
          </p>
          <div class="flex flex-wrap gap-2">
            <span
              class="rounded-full border border-white/10 bg-black/30 px-3 py-1.5 text-xs font-medium text-zinc-300"
            >
              Pago en efectivo
            </span>
            <span
              class="rounded-full border border-white/10 bg-black/30 px-3 py-1.5 text-xs font-medium text-zinc-300"
            >
              Entrega express
            </span>
          </div>
        </div>
      </div>

      <div class="w-full min-w-0 lg:w-1/2">
        <div class="space-y-8">
          {
            features.map((f, i) => {
              const Icon = icons[i];
              return (
                <div class="flex gap-6">
                  <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-white">
                    <Icon size={24} stroke-width={1.5} />
                  </div>
                  <div class="min-w-0 flex-1">
                    <h4 class="mb-2 text-xl font-bold text-white">{f.title}</h4>
                    <p class="leading-relaxed text-zinc-400">{f.desc}</p>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</section>
