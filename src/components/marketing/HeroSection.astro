---
import { Apple, PlayCircle } from "@lucide/astro";
---

<section
  id="hero-section"
  class="relative h-[100dvh] overflow-hidden bg-black md:h-auto md:min-h-screen md:pt-14 dot-grid"
>
  <div
    class="pointer-events-none absolute top-1/2 left-1/2 h-[700px] w-[700px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/4 blur-[80px]"
  >
  </div>

  <div
    class="container relative z-10 mx-auto flex h-full md:min-h-screen items-center justify-center px-6 md:px-4 md:-mt-12"
  >
    <div class="mx-auto w-full max-w-2xl text-center">
      <div
        data-hero-badge
        class="mb-5 inline-flex items-center justify-center rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-zinc-300 opacity-0"
      >
        <span class="mr-2 text-tuga-brand" aria-hidden="true">⚡</span>
        El Itacate de la Región
      </div>

      <h1
        data-hero-title
        class="mb-5 text-3xl font-black tracking-tighter text-white opacity-0 leading-[0.95] md:text-6xl lg:text-7xl"
      >
        <span class="block">Tu comida favorita,</span>
        <span
          class="block bg-gradient-to-b from-white via-tuga-brand/85 to-zinc-600 bg-clip-text text-transparent"
        >
          a un toque de distancia
        </span>
      </h1>

      <p
        data-hero-sub
        class="mx-auto mb-8 max-w-xl text-base font-medium tracking-tight text-zinc-400 opacity-0 leading-relaxed md:text-xl"
      >
        La plataforma de delivery simplificada para tu región. Conectamos con
        los restaurantes de siempre, sin complicaciones.
      </p>

      <div
        data-hero-cta
        class="flex flex-col flex-wrap items-center justify-center gap-4 opacity-0 sm:flex-row"
      >
        <button
          type="button"
          class="glass-button inline-flex h-11 items-center justify-center rounded-full px-6 text-sm font-bold transition-transform hover:scale-[1.02] active:scale-[0.97] md:h-14 md:px-8 md:text-lg"
        >
          <Apple class="mr-2 h-4 w-4 fill-current md:h-5 md:w-5" aria-hidden="true" />
          Descargar para iOS
        </button>

        <button
          type="button"
          class="inline-flex h-11 items-center justify-center rounded-full border border-zinc-800 px-6 text-sm font-bold text-zinc-400 transition-all hover:scale-[1.02] hover:border-tuga-brand/40 hover:bg-tuga-brand/10 hover:text-tuga-brand active:scale-[0.97] active:border-tuga-brand/40 active:bg-tuga-brand/10 active:text-tuga-brand md:h-14 md:px-8 md:text-lg"
        >
          <PlayCircle class="mr-2 h-4 w-4 md:h-5 md:w-5" aria-hidden="true" />
          Descargar para Android
        </button>
      </div>
    </div>
  </div>
</section>
