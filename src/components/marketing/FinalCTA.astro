---
import { Apple, PlayCircle, Download, Users, Store } from "@lucide/astro";

const stats = [
  {
    Icon: Download,
    value: "1.2M+",
    label: "Descargas",
    description: "Instalaciones activas en iOS y Android",
    chart: [
      { month: "Ene", total: "120K", value: 38 },
      { month: "Feb", total: "165K", value: 52 },
      { month: "Mar", total: "210K", value: 66 },
      { month: "Abr", total: "258K", value: 78 },
      { month: "May", total: "310K", value: 92 },
    ],
  },
  {
    Icon: Users,
    value: "850K+",
    label: "Usuarios clientes",
    description: "Personas ordenando cada mes en TugaApp",
    chart: [
      { month: "Ene", total: "72K", value: 30 },
      { month: "Feb", total: "95K", value: 45 },
      { month: "Mar", total: "120K", value: 58 },
      { month: "Abr", total: "143K", value: 70 },
      { month: "May", total: "168K", value: 82 },
    ],
  },
  {
    Icon: Store,
    value: "12K+",
    label: "Negocios registrados",
    description: "Restaurantes y comercios aliados en la plataforma",
    chart: [
      { month: "Ene", total: "2.1K", value: 24 },
      { month: "Feb", total: "3.8K", value: 40 },
      { month: "Mar", total: "6.2K", value: 56 },
      { month: "Abr", total: "8.9K", value: 72 },
      { month: "May", total: "12K", value: 88 },
    ],
  },
];
---

<section id="support" class="scroll-target overflow-hidden bg-black py-24 dot-grid">
  <div class="container mx-auto px-6 md:px-4">
    <div
      class="relative overflow-hidden rounded-[4rem] border border-white/5 bg-zinc-900/40 text-white backdrop-blur-xl"
    >
      <div
        class="absolute bottom-0 left-0 -mb-40 -ml-40 h-80 w-80 rounded-full bg-zinc-200 opacity-5 blur-[90px]"
      ></div>

      <div
        class="relative z-10 grid grid-cols-1 items-center gap-10 p-10 md:p-12 lg:grid-cols-2 lg:gap-14 lg:p-14"
      >
        <div class="max-w-2xl">
          <h2
            class="mb-6 text-center text-2xl font-black tracking-tighter leading-[1.05] md:text-5xl xl:text-6xl lg:text-left"
          >
            El futuro de <br />
            <span class="text-tuga-brand">la entrega</span> está aquí.
          </h2>

          <p
            class="mx-auto mb-8 max-w-lg text-center text-base font-medium tracking-tight text-zinc-400 md:text-lg xl:text-xl lg:mx-0 lg:text-left"
          >
            Únete a miles de usuarios disfrutando de la experiencia premium de
            TugaApp. Comienza hoy y obtén tu primera entrega gratis.
          </p>

          <div
            class="flex flex-col items-center justify-center gap-4 sm:flex-row lg:items-start lg:justify-start"
          >
            <button
              type="button"
              data-open-modal
              class="glass-button inline-flex h-14 items-center justify-center rounded-xl px-8 text-base font-bold transition-transform active:scale-[0.97]"
            >
              <Apple class="mr-2 h-5 w-5 fill-current" aria-hidden="true" />
              App Store
            </button>

            <button
              type="button"
              data-open-modal
              class="glass-button inline-flex h-14 items-center justify-center rounded-xl px-8 text-base font-bold transition-transform active:scale-[0.97]"
            >
              <PlayCircle class="mr-2 h-5 w-5" aria-hidden="true" />
              Play Store
            </button>
          </div>
        </div>

        <div class="w-full">
          <div
            class="mx-auto grid max-w-[500px] grid-cols-1 gap-3.5 md:gap-4 lg:ml-auto"
          >
            {
              stats.map((stat, idx) => {
                const Icon = stat.Icon;
                return (
                  <div
                    class="stat-card relative overflow-visible rounded-[1.6rem] border border-white/8 bg-white/[0.03] p-4 opacity-0 backdrop-blur-md md:p-5 md:cursor-default cursor-pointer"
                    data-stat-index={idx}
                  >
                    <div class="relative z-10 flex items-center gap-4">
                      {/* Icon — vertically centered via items-center on parent */}
                      <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-white/10 bg-white/[0.04] text-white">
                        <Icon size={20} stroke-width={1.8} />
                      </div>

                      {/* Text — stacked vertically so value+label never collide */}
                      <div class="min-w-0 flex-1">
                        <div class="text-xl font-black tracking-tight text-white md:text-2xl">
                          {stat.value}
                        </div>
                        <div class="text-xs font-semibold text-zinc-400 mb-0.5">
                          {stat.label}
                        </div>
                        <p class="text-xs leading-relaxed text-zinc-500">
                          {stat.description}
                        </p>
                        {/* Mobile hint */}
                        <p class="mt-1.5 text-[10px] font-medium text-tuga-brand/70 md:hidden">
                          Toca para ver detalle →
                        </p>
                      </div>

                      {/* Bars — desktop only */}
                      <div class="hidden md:flex h-20 w-28 shrink-0 items-end gap-2 md:w-32">
                        {stat.chart.map((item) => (
                          <div class="group/bar relative flex h-full flex-1 items-end">
                            <div class="pointer-events-none absolute -top-14 left-1/2 z-20 -translate-x-1/2 translate-y-1 whitespace-nowrap opacity-0 transition-all duration-200 group-hover/bar:translate-y-0 group-hover/bar:opacity-100">
                              <div class="rounded-xl border border-white/10 bg-zinc-950/95 px-3 py-2 shadow-[0_10px_30px_rgba(0,0,0,0.35)] backdrop-blur-md">
                                <div class="mb-1 text-[10px] tracking-[0.18em] text-zinc-500 uppercase">
                                  {item.month}
                                </div>
                                <div class="text-xs font-semibold text-white">
                                  {item.total} total
                                </div>
                              </div>
                            </div>
                            <div class="relative h-full w-full overflow-hidden rounded-full border border-white/6 bg-white/8">
                              <div
                                class="chart-bar-fill absolute bottom-0 left-0 w-full origin-bottom rounded-full bg-tuga-brand/80 transition-all duration-300 group-hover/bar:scale-y-[1.06] group-hover/bar:bg-tuga-brand"
                                data-height={`${item.value}%`}
                                style="height: 0%"
                              />
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                );
              })
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stat detail modal (mobile) -->
<div
  id="stat-modal"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  class="fixed inset-0 z-[500] hidden flex items-center justify-center px-5"
>
  <div id="stat-modal-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-md opacity-0 transition-opacity duration-200"></div>
  <div
    id="stat-modal-card"
    class="relative z-10 w-full max-w-sm scale-95 opacity-0 overflow-hidden rounded-[2rem] border border-white/10 bg-zinc-950 shadow-[0_30px_80px_rgba(0,0,0,0.6)] transition-all duration-300"
  >
    <div class="h-px w-full bg-gradient-to-r from-transparent via-tuga-brand/60 to-transparent"></div>
    <div class="flex items-center justify-between border-b border-white/8 px-6 py-4">
      <h3 id="stat-modal-title" class="font-black tracking-tight text-white"></h3>
      <button id="stat-modal-close" type="button" aria-label="Cerrar"
        class="flex h-8 w-8 items-center justify-center rounded-full bg-zinc-800 text-zinc-400 transition-colors hover:bg-zinc-700 active:scale-95">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
    <div id="stat-modal-body" class="px-6 py-5"></div>
  </div>
</div>

<script define:vars={{ statsData: stats.map(s => ({ value: s.value, label: s.label, description: s.description, chart: s.chart.map(c => ({ month: c.month, total: c.total, value: c.value })) })) }}>
  const modal    = document.getElementById("stat-modal");
  const backdrop = document.getElementById("stat-modal-backdrop");
  const card     = document.getElementById("stat-modal-card");
  const titleEl  = document.getElementById("stat-modal-title");
  const bodyEl   = document.getElementById("stat-modal-body");
  const closeBtn = document.getElementById("stat-modal-close");

  function openStatModal(idx) {
    const s = statsData[idx];
    if (!s) return;
    titleEl.textContent = `${s.value} ${s.label}`;
    bodyEl.innerHTML = `
      <p class="mb-4 text-sm text-zinc-400">${s.description}</p>
      <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.2em] text-zinc-500">Progreso mensual</p>
      <div class="space-y-3">
        ${s.chart.map(item => `
          <div class="flex items-center gap-3">
            <span class="w-8 text-xs text-zinc-500 shrink-0">${item.month}</span>
            <div class="flex-1 h-2 rounded-full overflow-hidden bg-white/8">
              <div class="h-full rounded-full bg-tuga-brand/80" style="width:${item.value}%"></div>
            </div>
            <span class="w-12 text-right text-xs font-semibold text-zinc-300">${item.total}</span>
          </div>
        `).join('')}
      </div>
    `;
    modal.classList.remove("hidden");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => requestAnimationFrame(() => {
      backdrop.classList.remove("opacity-0");
      card.classList.remove("scale-95", "opacity-0");
      card.classList.add("scale-100");
    }));
  }

  function closeStatModal() {
    card.classList.add("scale-95", "opacity-0");
    card.classList.remove("scale-100");
    backdrop.classList.add("opacity-0");
    setTimeout(() => {
      modal.classList.add("hidden");
      modal.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    }, 300);
  }

  document.querySelectorAll("[data-stat-index]").forEach(el => {
    el.addEventListener("click", () => {
      if (window.innerWidth < 768) {
        openStatModal(Number(el.dataset.statIndex));
      }
    });
  });

  closeBtn?.addEventListener("click", closeStatModal);
  backdrop?.addEventListener("click", closeStatModal);
  document.addEventListener("keydown", e => { if (e.key === "Escape") closeStatModal(); });
</script>
