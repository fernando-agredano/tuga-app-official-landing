---
import { Search, ShoppingBag, Bell, PackageCheck } from "@lucide/astro";

const steps = [
  {
    title: "Explorar",
    description:
      "Busca negocios desde la app, descubre opciones cercanas y encuentra fácilmente lo que quieres pedir.",
    color: "from-blue-500/10 to-transparent",
  },
  {
    title: "Solicitar",
    description:
      "Selecciona tus productos y envía tu pedido en segundos. El negocio lo recibe, lo acepta y confirma la orden.",
    color: "from-purple-500/10 to-transparent",
  },
  {
    title: "Actualizaciones",
    description:
      "El cliente recibe notificaciones cuando el pedido es aceptado, cuando está listo, cuando va en camino y cuando ha llegado.",
    color: "from-orange-500/10 to-transparent",
  },
  {
    title: "Entrega confirmada",
    description:
      "Una vez que el cliente recibe el pedido, el negocio también recibe la confirmación de que la entrega fue completada.",
    color: "from-tuga-brand/15 to-transparent",
  },
] as const;

const icons = [Search, ShoppingBag, Bell, PackageCheck];
---

<section
  id="how-it-works"
  class="scroll-target overflow-hidden bg-black pt-8 pb-14 md:py-24 dot-grid"
>
  <div class="container mx-auto px-6 md:px-4">
    <div class="mb-12 text-center md:mb-20">
      <h2 class="mb-4 text-sm font-bold tracking-[0.3em] text-zinc-500 uppercase">
        Proceso
      </h2>
      <h3 class="text-3xl font-black tracking-tighter text-white md:text-6xl">
        Cómo funciona <span class="text-tuga-brand">TugaApp</span>.
      </h3>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((step, index) => {
          const Icon = icons[index];
          return (
          <div class="how-card group relative rounded-2xl border border-zinc-800/50 bg-zinc-900/40 p-5 transition-colors lg:hover:border-zinc-700/50 active:border-zinc-700/50 md:rounded-3xl md:p-8">
            <div
              class:list={[
                "absolute inset-0 rounded-2xl bg-gradient-to-b opacity-0 transition-opacity duration-300 lg:group-hover:opacity-100 group-active:opacity-100 md:rounded-3xl",
                step.color,
              ]}
            />

            <div class="relative z-10">
              <div class="mb-4 inline-flex rounded-xl bg-zinc-800 p-3 text-white transition-transform duration-300 lg:group-hover:scale-105 group-active:scale-105 md:mb-6 md:rounded-2xl md:p-4">
                <Icon size={22} stroke-width={1.5} class="md:h-8 md:w-8" />
              </div>
              <h4 class="mb-2 text-lg font-bold text-white md:mb-4 md:text-2xl">{step.title}</h4>
              <p class="text-sm leading-relaxed text-zinc-400 md:text-base">{step.description}</p>
            </div>

            <span class="absolute top-4 right-5 text-4xl font-black text-white/5 transition-colors group-hover:text-white/10 md:top-6 md:right-8 md:text-5xl">
              0{index + 1}
            </span>
          </div>
          );
        })
      }
    </div>
  </div>
</section>
