---
import { Turtle } from "@lucide/astro";
---

<div
  id="splash-overlay"
  class="fixed inset-0 z-[101] flex flex-col items-center justify-center bg-black text-white"
  aria-live="polite"
>
  <div class="flex flex-col items-center gap-5 sm:gap-6">
    <div id="splash-logo">
      <div class="flex flex-col items-center select-none leading-none">
        <div class="flex items-center justify-center gap-3 sm:gap-4 md:gap-5">
          <Turtle
            class="h-10 w-10 shrink-0 text-tuga-brand sm:h-12 sm:w-12 md:h-14 md:w-14"
            stroke-width={1.75}
            aria-hidden="true"
          />
          <span
            class="text-4xl font-black tracking-[-0.06em] text-white sm:text-5xl md:text-6xl"
          >
            Tuga<span class="text-tuga-brand">App</span>
          </span>
        </div>
      </div>
    </div>

    <div
      id="splash-byte"
      class="text-sm font-medium tracking-widest uppercase text-zinc-500 opacity-0"
    >
      Powered by Byte
    </div>
  </div>
</div>
